# Core database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# Optional direct or migration-specific connection overrides.
DIRECT_URL=
DRIZZLE_DATABASE_URL=

# Core app and authentication
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_PLATFORM_DOMAIN=localhost:3000

# Credential encryption and privacy
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
RECOVERY_TOKEN_SECRET=replace-with-a-long-random-recovery-token-secret
CHECKIN_PASS_SECRET=replace-with-a-dedicated-32-character-check-in-pass-secret
INBOX_REPLY_ROUTING_SECRET=replace-with-a-dedicated-32-character-routing-secret
PUBLICATION_TRACKING_SECRET=replace-with-a-dedicated-32-character-tracking-secret
PUBLIC_FORM_SUBMISSION_SECRET=replace-with-a-dedicated-32-character-form-secret
PUBLICATION_ABUSE_SECRET=replace-with-a-dedicated-32-character-abuse-secret
IP_HASH_SALT=replace-with-a-random-ip-hash-salt

# File uploads
UPLOADTHING_TOKEN=replace-with-uploadthing-token
UPLOADTHING_SECRET=replace-with-uploadthing-secret

# Redis-backed vector store
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase clients
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# AI provider keys are encrypted organization/location credentials managed in
# the CRM. Deployment environment variables are never used as tenant accounts.

# Polar subscriptions
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SUCCESS_URL=http://localhost:3000
NEXT_PUBLIC_POLAR_PORTAL_URL=
# Comma-separated Polar product IDs that grant organization communications.
AUREA_COMMUNICATIONS_EMAIL_PRODUCT_IDS=
AUREA_COMMUNICATIONS_SMS_PRODUCT_IDS=
AUREA_COMMUNICATIONS_VOICE_PRODUCT_IDS=

# Google OAuth, Calendar, Gmail, Drive, and Forms
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_WEBHOOK_BASE_URL=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_VERIFICATION_TOKEN=
GMAIL_PUBSUB_OIDC_AUDIENCE=
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=

# Microsoft OAuth, Outlook, and OneDrive
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Slack and Discord OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Facebook and WhatsApp OAuth scopes
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_DEFAULT_SCOPES=
FACEBOOK_OPTIONAL_SCOPES=

# Telegram webhooks
TELEGRAM_WEBHOOK_BASE_URL=

# Stripe payments, webhooks, and Connect
# Stripe Connect platform infrastructure only. Tenant authorization comes from
# an organization/location-scoped StripeConnection, never from this key alone.
STRIPE_SECRET_KEY=
STRIPE_CLIENT_ID=
# Canonical commerce endpoint. Legacy endpoint-specific secrets remain supported
# during provider migration so existing Stripe destinations can be rotated safely.
STRIPE_COMMERCE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_MEMBERSHIP_WEBHOOK_SECRET=
STRIPE_INVOICE_WEBHOOK_SECRET=
STRIPE_BOOKING_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=

# Platform-managed communications infrastructure. These credentials never select
# a tenant; every operation must first resolve an organization-owned binding.
AUREA_PLATFORM_RESEND_API_KEY=
AUREA_PLATFORM_RESEND_WEBHOOK_SECRET=
AUREA_PLATFORM_RESEND_PREVIOUS_WEBHOOK_SECRET=
AUREA_PLATFORM_RESEND_FALLBACK_FROM_EMAIL=
AUREA_PLATFORM_RESEND_FALLBACK_FROM_NAME=
AUREA_PLATFORM_RESEND_FALLBACK_REPLY_TO=
AUREA_TWILIO_PARENT_ACCOUNT_SID=
AUREA_TWILIO_PARENT_AUTH_TOKEN=
AUREA_TWILIO_SMS_SEGMENT_RESERVATION_AMOUNT=
AUREA_TWILIO_VOICE_MINUTE_RESERVATION_AMOUNT=
AUREA_VOICE_VERIFICATION_COOLDOWN_SECONDS=600
AUREA_COMMUNICATIONS_WEBHOOK_RETENTION_DAYS=30

# Analytics, maps, and ad destinations
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_MAPBOX_TOKEN=
# Meta, Google Ads, and TikTok conversion credentials are encrypted per
# organization/location in Settings > Provider accounts. There is no global fallback.

# Build observability
SENTRY_AUTH_TOKEN=

# Local scripts and diagnostics
MINDBODY_EXPORT_DIR=
MINDBODY_IMPORT_JOB_ID=
DEBUG_MINDBODY_BACKFILL=
LOG_GEO_FAILURES=
DEV_GEOIP_IP=
# Demo data is enabled automatically outside production. Production requires an
# explicit opt-in and should only target a dedicated empty demo location.
DEMO_DATA_ENABLED=false
